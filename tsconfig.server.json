  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist/server",
    "rootDir": "./server",
    "declaration": false,
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["server"],
  "exclude": ["node_modules"]
}
